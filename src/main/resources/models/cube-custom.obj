# cube-tex.obj
# Import into Blender with Y-forward, Z-up
#
# Vertices:                        Faces:
#      f-------g                          +-------+
#     /.      /|                         /.  5   /|  3 back
#    / .     / |                        / .     / |
#   e-------h  |                   2   +-------+ 1|
#   |  b . .|. c      z          right |  . . .|. +
#   | .     | /       | /y             | . 4   | /
#   |.      |/        |/               |.      |/
#   a-------d         +---- x          +-------+
#                                           6
#                                        bottom

# Material defined in separate file.
mtllib cube.mtl

g cube

# Vertices
v -0.5 -0.5 -0.5  # 1 a
v -0.5 -0.5  0.5  # 2 b
v  0.5 -0.5  0.5  # 3 c
v  0.5 -0.5 -0.5  # 4 d
v -0.5  0.5 -0.5  # 5 e
v -0.5  0.5  0.5  # 6 f
v  0.5  0.5  0.5  # 7 g
v  0.5  0.5 -0.5  # 8 h
v -0.5 -0.5 -0.5  # 9 a
v -0.5 -0.5  0.5  # 10 b
v  0.5 -0.5  0.5  # 11 c
v  0.5 -0.5 -0.5  # 12 d
v -0.5  0.5 -0.5  # 13 e
v -0.5  0.5  0.5  # 14 f
v  0.5  0.5  0.5  # 15 g
v  0.5  0.5 -0.5  # 16 h
v -0.5 -0.5 -0.5  # 17 a
v -0.5 -0.5  0.5  # 18 b
v  0.5 -0.5  0.5  # 19 c
v  0.5 -0.5 -0.5  # 20 d
v -0.5  0.5 -0.5  # 21 e
v -0.5  0.5  0.5  # 22 f
v  0.5  0.5  0.5  # 23 g
v  0.5  0.5 -0.5  # 24 h

# Normal vectors
# One for each face. Shared by all vertices in that face.
vn  1.0  0.0  0.0  # 1 cghd
vn -1.0  0.0  0.0  # 2 aefb
vn  0.0  1.0  0.0  # 3 gcbf
vn  0.0 -1.0  0.0  # 4 dhea
vn  0.0  0.0  1.0  # 5 hgfe
vn  0.0  0.0 -1.0  # 6 cdab

# Texture
# (u,v) coordinate into texture map image, ranging from 0.0 - 1.0.
#  +---a---b---+---+
#  |   | 5 |   |   |
#  c---d---e---f---+
#  | 2 | 4 | 1 |   |     v
#  g---h---i---j---+     |
#  |   | 6 |   |   |     |
#  +---k---l---+---+     +---- u
#  |   | 3 |   |   |
#  +---m---n---+---+
vt 0.25 1.00  # 1 a
vt 0.50 1.00  # 2 b
vt 0.00 0.75  # 3 c
vt 0.25 0.75  # 4 d
vt 0.50 0.75  # 5 e
vt 0.75 0.75  # 6 f
vt 0.00 0.50  # 7 g
vt 0.25 0.50  # 8 h
vt 0.50 0.50  # 9 i
vt 0.75 0.50  # 10 j
vt 0.25 0.25  # 11 k
vt 0.50 0.25  # 12 l
vt 0.25 0.00  # 13 m
vt 0.50 0.00  # 14 n

# Define material for the following faces
usemtl texture

# Faces v/vt/vn
#   3-------2
#   | -     |
#   |   #   |  Each face = 2 triangles (ccw)
#   |     - |            = 1-2-3 + 1-3-4
#   4-------1

# Face 1: ijfe = ijf + ife
f 3/9/1 4/10/1 8/6/1
f 3/9/1 8/6/1 7/5/1

# Face 2: ghdc = ghd + gdc
f 1/7/2 2/8/2 6/4/2
f 1/7/2 6/4/2 5/3/2

# Face 3: lkmn = lkm + lmn
f 15/12/3 14/11/3 10/13/3
f 15/12/3 10/13/3 11/14/3

# Face 4: hied = hie + hed
f 12/8/4 9/9/4 13/5/4
f 12/8/4 13/5/4 16/4/4

# Face 5: ebad = eba + ead
f 24/5/5 21/2/5 22/1/5
f 24/5/5 22/1/5 23/4/5

# Face 6: lihk = lih + lhk
f 19/12/6 18/9/6 17/8/6
f 19/12/6 17/8/6 20/11/6
